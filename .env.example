# Database (optional — defaults to SQLite at ./beyond_fit.db)
DATABASE_URL=

# LLM / OpenRouter (required)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL_ID=google/gemini-3.1-flash-lite-preview
LLM_TEMPERATURE=0.4

# Telegram (required)
TELEGRAM_BOT_TOKEN=
ADMIN_CHAT_ID=

# Email / SMTP (required for plan delivery)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Feature flags
FEATURE_NUTRITION_ENABLED=false
