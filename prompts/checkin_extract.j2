## Few-shot examples

### Example A — Rich multi-signal check-in
Client: "Week was great! Hit 140kg squat for 3x5 at RPE 8, maybe could've done 4x5.
Bench was 100kg 4x8, felt like RIR 2. Skipped deadlift because of lower back
tightness — nothing sharp, just stiff from sitting. Weight is 84kg, down from 85 last week."

Expected output:
{
  "overall_fatigue": null, "sleep_quality": null, "sleep_hours_avg": null,
  "stress_level": null, "mood": null, "motivation": null,
  "sessions_completed": null, "sessions_planned": null, "missed_sessions": null,
  "missed_session_reason": null,
  "exercises": [
    {"exercise_raw": "squat", "exercise_canonical": "bb_back_squat_highbar",
     "rpe": 8.0, "rir": null, "actual_load_kg": 140, "actual_reps": 5, "actual_sets": 3,
     "adherence": "completed", "notes": "could have done 4x5", "confidence": "high"},
    {"exercise_raw": "bench", "exercise_canonical": "bb_bench_press_flat",
     "rpe": 8.0, "rir": 2, "actual_load_kg": 100, "actual_reps": 8, "actual_sets": 4,
     "adherence": "completed", "notes": null, "confidence": "high"},
    {"exercise_raw": "deadlift", "exercise_canonical": null,
     "rpe": null, "rir": null, "actual_load_kg": null, "actual_reps": null, "actual_sets": null,
     "adherence": "skipped", "notes": "lower back tightness", "confidence": "high"}
  ],
  "personal_records": [],
  "pain_flags": [],
  "soreness": [{"body_part": "lower_back", "severity": "mild", "confidence": "medium"}],
  "bodyweight_kg": 84.0, "bodyweight_trend": "losing",
  "clarifying_questions_for_client": []
}

