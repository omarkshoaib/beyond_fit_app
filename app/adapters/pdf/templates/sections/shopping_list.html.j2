<div class="page-break-before">
  <div class="section-header section-header--nutrition">
    <h2>Weekly Shopping List</h2>
    <p>Quantities cover the full 7-day plan</p>
  </div>

  <div class="three-col">
    {% for category, items in shopping_list.items() %}
    <div class="shopping-category no-break">
      <div class="shopping-category__title">{{ category | title }}</div>
      {% for item in items %}
      <div class="shopping-item">
        <span class="shopping-item__name">{{ item.name }}</span>
        <span class="shopping-item__qty">{{ item.total_grams | round | int }} g</span>
      </div>
      {% endfor %}
    </div>
    {% endfor %}
  </div>
</div>
