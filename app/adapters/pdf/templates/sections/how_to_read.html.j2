<div class="page-break-before">
  <div class="section-header">
    <h2>How to Read Your Plan</h2>
    <p>Key terms, symbols, and notation used throughout this document</p>
  </div>

  <div class="two-col" style="margin-bottom: var(--space-lg);">
    <div>
      <h4 style="margin-bottom: var(--space-sm);">Intensity Notation</h4>
      <table class="info-table">
        <thead>
          <tr><th>Symbol</th><th>Meaning</th></tr>
        </thead>
        <tbody>
          <tr><td class="mono">RPE 8</td>
              <td>Rate of Perceived Exertion — 2 reps left in the tank</td></tr>
          <tr><td class="mono">RIR 2</td>
              <td>Reps In Reserve — identical to RPE 8 at most loads</td></tr>
          <tr><td class="mono">@70%</td>
              <td>Percentage of your estimated 1-rep max</td></tr>
          <tr><td class="mono">BW</td>
              <td>Bodyweight — no external load</td></tr>
        </tbody>
      </table>
    </div>
    <div>
      <h4 style="margin-bottom: var(--space-sm);">Tempo Notation (e.g. 3-0-1-0)</h4>
      <table class="info-table">
        <thead>
          <tr><th>Position</th><th>Phase</th><th>Example</th></tr>
        </thead>
        <tbody>
          <tr><td class="mono">1st</td><td>Eccentric (lowering)</td><td class="mono">3s down</td></tr>
          <tr><td class="mono">2nd</td><td>Pause at bottom</td><td class="mono">0s pause</td></tr>
          <tr><td class="mono">3rd</td><td>Concentric (lifting)</td><td class="mono">1s up</td></tr>
          <tr><td class="mono">4th</td><td>Pause at top</td><td class="mono">0s pause</td></tr>
          <tr><td class="mono">X</td><td>Explosive / as fast as possible</td><td>—</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <div class="two-col" style="margin-bottom: var(--space-lg);">
    <div>
      <h4 style="margin-bottom: var(--space-sm);">Rest Periods</h4>
      <table class="info-table">
        <thead><tr><th>Lift Type</th><th>Target Rest</th></tr></thead>
        <tbody>
          <tr><td>Main compound (1–5 reps)</td><td class="mono">3–4 min</td></tr>
          <tr><td>Hypertrophy (6–12 reps)</td><td class="mono">2–2.5 min</td></tr>
          <tr><td>Isolation / accessory</td><td class="mono">60–90 s</td></tr>
        </tbody>
      </table>
    </div>
    <div>
      <h4 style="margin-bottom: var(--space-sm);">Plan Structure</h4>
      <table class="info-table">
        <thead><tr><th>Term</th><th>Meaning</th></tr></thead>
        <tbody>
          <tr><td><span class="badge badge-accent">A1</span></td>
              <td>Main lift — the primary compound movement for the session</td></tr>
          <tr><td><span class="badge" style="background:#94A3B8;color:#fff;">B1</span></td>
              <td>Primary accessory — secondary compound or heavy isolation</td></tr>
          <tr><td><span class="badge badge-muted">C1</span></td>
              <td>Isolation — targeted single-joint work</td></tr>
          <tr><td><span class="badge badge-deload">Deload</span></td>
              <td>Week 5: 50% volume, 60% load, RPE ≤ 6</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <div class="callout callout--info">
    <p><strong>Warm-up sets</strong> are listed under each main compound. They are <em>not</em>
    counted in weekly volume. Complete them as shown: bar × 8, then 50% × 5, then 70% × 3,
    then optional primers at 85–90% for heavy days.</p>
  </div>
</div>
